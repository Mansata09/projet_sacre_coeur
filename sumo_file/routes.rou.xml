<?xml version="1.0" encoding="UTF-8"?>
<routes>

    <!-- TYPES DE VEHICULES -->
    <vType id="passenger" vClass="passenger"
            accel="2.6" decel="4.5" sigma="0.2"
            length="4.5" maxSpeed="13.89" color="1,1,0"
            laneChangeModel="LC2013"
            lcStrategic="1.0" lcCooperative="1.0"
            lcSpeedGain="5.0" lcKeepRight="0.0"
            lcAssertive="1.0" lcOvertakeRight="1.0"/>

    <vType id="tata" vClass="bus"
            accel="1.5" decel="3.0" sigma="0.5"
            length="8.0" maxSpeed="11.11" color="1,0.5,0"
            laneChangeModel="LC2013"
            lcStrategic="1.5" lcSpeedGain="2.0"/>

    <vType id="bus" vClass="bus"
            accel="1.5" decel="3.0" sigma="0.5"
            length="12.0" maxSpeed="11.11" color="0,1,0"
            laneChangeModel="LC2013" lcStrategic="1.5"/>

    <vType id="brt" vClass="tram"
            accel="1.2" decel="2.5" sigma="0.1"
            length="18.0" maxSpeed="12.50" color="0,0,1"
            guiShape="bus"/>

    <vType id="emergency" vClass="emergency"
            accel="3.0" decel="5.0" sigma="0.1"
            length="6.0" maxSpeed="16.67" color="1,0,0"
            guiShape="emergency"/>

    <!-- ROUTES -->
    <route id="r_N1_N2" edges="N1_N0 N0_N2"/>
    <route id="r_N1_N3" edges="N1_N0 N0_N3"/>
    <route id="r_N1_N4" edges="N1_N0 N0_N4"/>

    <route id="r_N2_N1" edges="N2_N0 N0_N1"/>
    <route id="r_N2_N3" edges="N2_N0 N0_N3"/>
    <route id="r_N2_N4" edges="N2_N0 N0_N4"/>

    <route id="r_N3_N1" edges="N3_N0 N0_N1"/>
    <route id="r_N3_N2" edges="N3_N0 N0_N2"/>
    <route id="r_N3_N4" edges="N3_N0 N0_N4"/>

    <route id="r_N4_N1" edges="N4_N0 N0_N1"/>
    <route id="r_N4_N2" edges="N4_N0 N0_N2"/>
    <route id="r_N4_N3" edges="N4_N0 N0_N3"/>

