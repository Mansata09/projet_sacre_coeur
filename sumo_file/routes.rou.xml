    <route id="BRT_N4_to_N3" edges="N4_N0_BRT N0_N3_BRT"/>

    <!-- ========================= -->
    <!-- begin=0 : BRT + TATA + BUS + MATIN -->
    <!-- ========================= -->

    <!-- BRT toute la journée -->
    <flow id="BRT_descente" type="brt" begin="0" end="3600"
            period="90" route="BRT_N3_to_N4" departLane="free"/>

    <!-- Tata toute la journée -->
    <!-- <flow id="Tata_1" type="tata" begin="0" end="3600" period="20" route="r_N1_N3" departLane="free"/>
    <flow id="Tata_2" type="tata" begin="0" end="3600" period="50" route="r_N3_N1" departLane="free"/>
    <flow id="Tata_3" type="tata" begin="0" end="3600" period="30" route="r_N2_N4" departLane="free"/>
    <flow id="Tata_4" type="tata" begin="0" end="3600" period="10" route="r_N4_N2" departLane="free"/> -->

    <!-- Bus toute la journée -->
