    <flow id="Bus_1" type="bus" begin="0" end="1000" probability="0.20" route="r_N3_N4" departLane="free"/>
    <flow id="Bus_2" type="bus" begin="0" end="1000" probability="0.10" route="r_N3_N1" departLane="free"/>
    <flow id="Bus_3" type="bus" begin="0" end="1000" probability="0.30" route="r_N2_N3" departLane="free"/>
    <flow id="Bus_4" type="bus" begin="0" end="1000" probability="0.050" route="r_N4_N3" departLane="free"/>
